# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database (Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/mdm_core?schema=public"

# Redis (optional — for outbox / caching)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
